# This config is a STUB! This should never be generated.
# Use the default lua config from https://github.com/hyprwm/Hyprland/blob/main/example/hyprland.lua

#Nvidia Environment Variables
 
env = LIBVA_DRIVER_NAME,nvidia
env = XDG_SESSION_TYPE,wayland
env = GBM_BACKEND,nvidia-drm
env = __GLX_VENDOR_LIBRARY_NAME,nvidia
env = WLR_NO_HARDWARE_CURSORS,1

#Monitor Scale
monitor=,highres,auto,1.25

#Gap
general {
    gaps_in = 2     # Khoảng cách giữa các cửa sổ với nhau (ví dụ: 5 pixel)
    gaps_out = 5   # Khoảng cách giữa cửa sổ với viền màn hình (ví dụ: 10 pixel)
}

#Animation
animations {
    enabled = true
    
    # Có thể giữ lại hiệu ứng chuyển đổi không gian làm việc (workspace)
    animation = workspaces, 1, 3, default
}





$mainMod = SUPER
$terminal = kitty
$fileManager = dolphin
$menu = wofi --show drun

bind = $mainMod, Q, exec, $terminal
bind = $mainMod, C, killactive,
bind = $mainMod, M, exec, command -v hyprshutdown >/dev/null 2>&1 && hyprshutdown || hyprctl dispatch exit
bind = $mainMod, E, exec, $fileManager
bind = $mainMod, V, togglefloating,
bind = $mainMod, D, exec,pkill wofi ||  $menu

#Waybar Configuration
exec-once = waybar
